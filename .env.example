# Postgres 连接串。本地:postgres://root@127.0.0.1:5432/egouu
# docker-compose 部署:主机名须为服务名 postgres,凭据与 POSTGRES_* 一致,如
#   postgres://egouu:egouu@postgres:5432/egouu
DATABASE_URL=postgres://root@127.0.0.1:5432/egouu
PAYLOAD_SECRET=YOUR_SECRET_HERE
# 草稿预览鉴权密钥(§18):强随机;后台「预览」按钮与 /preview 路由校验用
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE

# ── 阶段 5 表单与通知(§5 / §10)──
# 咨询通知收件人(未配则跳过对应通道)。dev 无 SMTP/SMS 凭据时,发送内容打印到控制台。
NOTIFY_EMAIL=lead@example.com
NOTIFY_PHONE=13800000000
# 可信客户端 IP 头(§10):CDN/反代注入的单值头名,如 X-Real-IP / CF-Connecting-IP。
# 留空 → 限流回退单桶(dev/无代理)。切勿填裸 x-forwarded-for(可伪造)。
TRUSTED_IP_HEADER=
# 联系表单限流:每 IP 每 10min 提交上限(默认 20)。共享 NAT/CGN 环境如误挡真人可上调。
INQUIRY_RATE_MAX=
# 邮件 SMTP(配了 SMTP_HOST 才走真实发送;当前发送逻辑待接入,见 src/lib/notify.ts)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
# 短信(配了 SMS_ACCESS_KEY 才走真实发送;逻辑待接入)。需短信签名 + 模板报备。
SMS_ACCESS_KEY=
SMS_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_ID=

# ── 阶段 6 SEO(§12)──
# 站点绝对基址(canonical/OG/sitemap 用)= 主域名。生产用 apex https://egouu.com;
# www.egouu.com 由 next.config 的 redirects() 自动 308 归一到此(主域名唯一,SEO)。
# 改主域名只改这一处;dev 留空回退 http://localhost:3000。注:NEXT_PUBLIC_* 构建期内联,改值需重构镜像。
NEXT_PUBLIC_SERVER_URL=https://egouu.com
# 站点环境:staging 时全站 noindex + sitemap 空;生产留空。
NEXT_PUBLIC_SITE_ENV=
# 对象存储/CDN 域(用于 CSP img/media/connect 白名单;dev 走同源留空,阶段7 配)。
NEXT_PUBLIC_MEDIA_HOST=

# ── 阶段 7 部署上线(§17)──
# 首个管理员 bootstrap(仅首次部署用;release job 在暴露 /admin 前建好首管理员,消除抢注空窗)。
# 登录后请尽快改密;之后可从环境移除。
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
# docker-compose 的 postgres 服务凭据(须与上方 DATABASE_URL 中的用户/库名一致)。
POSTGRES_USER=egouu
POSTGRES_PASSWORD=
POSTGRES_DB=egouu
