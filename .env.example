DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE
# 草稿预览鉴权密钥(§18):强随机;后台「预览」按钮与 /preview 路由校验用
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE

# ── 阶段 5 表单与通知(§5 / §10)──
# 咨询通知收件人(未配则跳过对应通道)。dev 无 SMTP/SMS 凭据时,发送内容打印到控制台。
NOTIFY_EMAIL=lead@example.com
NOTIFY_PHONE=13800000000
# 可信客户端 IP 头(§10):CDN/反代注入的单值头名,如 X-Real-IP / CF-Connecting-IP。
# 留空 → 限流回退单桶(dev/无代理)。切勿填裸 x-forwarded-for(可伪造)。
TRUSTED_IP_HEADER=
# 邮件 SMTP(配了 SMTP_HOST 才走真实发送;当前发送逻辑待接入,见 src/lib/notify.ts)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
# 短信(配了 SMS_ACCESS_KEY 才走真实发送;逻辑待接入)。需短信签名 + 模板报备。
SMS_ACCESS_KEY=
SMS_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_ID=

# ── 阶段 6 SEO(§12)──
# 站点绝对基址(canonical/OG/sitemap 用)。生产填备案域名;dev 留空回退 http://localhost:3000。
NEXT_PUBLIC_SERVER_URL=
# 站点环境:staging 时全站 noindex + sitemap 空;生产留空。
NEXT_PUBLIC_SITE_ENV=
# 对象存储/CDN 域(用于 CSP img/media/connect 白名单;dev 走同源留空,阶段7 配)。
NEXT_PUBLIC_MEDIA_HOST=
